import NavLinks from "@/components/NavLinks.astro";
import { t } from "i18next";
---
<footer>
  <div class="mx-auto max-w-6xl px-6 py-10 flex flex-col items-center gap-6">
    <div>
      <p id="copyright" class="text-sm text-center mb-2">{t('footer_made')}</p>
      <p class="text-sm text-center">{t('hatsune_miku_copyright')}</p>
      <p class="text-sm text-center">{t('not_affiliated')}</p>
    </div>

    <div class="hidden md:block">
      <NavLinks/>
    </div>
  </div>
</footer>
<script>
  const copyright = document.querySelector('#copyright')
  const now = new Date();

  if (copyright) {
    copyright.innerHTML = copyright.textContent.replace('2025', now.getFullYear().toString())
  }
</script>