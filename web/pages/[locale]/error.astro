import PageLayout from '@/layout/page.astro'
import { languagePaths } from "@/i18n/i18n.ts"
import i18n, {t} from "i18next";
import {TriangleAlert} from "lucide-react";

export function getStaticPaths() {
  return languagePaths();
}

await i18n.changeLanguage(Astro.currentLocale)
---
<PageLayout>
  <div class="flex flex-1 flex-col items-center justify-center">
    <TriangleAlert className="text-red-500" size={100} />
    <p class="text-2xl mt-3 px-5 text-center">{t('system_error')}</p>
  </div>
</PageLayout>
